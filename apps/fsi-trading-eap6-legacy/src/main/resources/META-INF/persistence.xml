<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_1_0.xsd"
             version="1.0">
  <persistence-unit name="fsiTradingPU" transaction-type="JTA">
    <jta-data-source>java:jboss/datasources/ExampleDS</jta-data-source>
    <properties>
      <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
      <property name="hibernate.show_sql" value="false"/>
      <!-- Propiedades legacy intencionales para disparar más hallazgos al ir a Hibernate 6 / Quarkus -->
      <property name="hibernate.ejb.metamodel.population" value="enabled"/>
      <property name="hibernate.ejb.cfgfile" value="hibernate.cfg.xml"/>
      <property name="hibernate.ejb.xml_files" value="META-INF/orm.xml"/>
      <property name="hibernate.hql.bulk_id_strategy" value="org.hibernate.hql.spi.id.local.LocalTemporaryTableBulkIdStrategy"/>
      <property name="hibernate.classLoader.application" value="current"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
    </properties>
  </persistence-unit>
</persistence>

