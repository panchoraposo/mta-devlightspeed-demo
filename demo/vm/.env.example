VM_USER=ec2-user
VM_SSH_KEY=~/.ssh/id_rsa

# VM running JBoss EAP 7 (legacy, non-container)
VM_EAP7_HOST=eap7-legacy.example.com
VM_EAP7_HTTP_PORT=8080
VM_EAP7_MGMT_PORT=9990

# Local path to EAP 7 ZIP (downloaded from Red Hat Customer Portal)
# Example: ~/Downloads/jboss-eap-7.4.0.zip
EAP7_ZIP_PATH=

# PostgreSQL (on the same EAP7 VM)
PG_DB=payments
PG_USER=payments
PG_PASSWORD=payments

# VM running Spring Boot 2 legacy JAR
VM_INVENTORY_HOST=inventory-legacy.example.com
VM_INVENTORY_PORT=8082

