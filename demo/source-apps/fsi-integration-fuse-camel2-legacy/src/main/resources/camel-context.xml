<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:camel="http://camel.apache.org/schema/spring"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://camel.apache.org/schema/spring http://camel.apache.org/schema/spring/camel-spring.xsd">

  <bean id="legacyTransform" class="com.acme.fsi.integration.LegacyTransformProcessor"/>

  <!-- Legacy Camel 2 Spring XML DSL route (muy común en Fuse 6/7 con Camel 2) -->
  <camel:camelContext id="fsiCamel2">
    <camel:route id="market-data-poller">
      <camel:from uri="timer:marketData?period=5000"/>
      <camel:setBody>
        <camel:simple>{"feed":"MARKET_DATA","ts":"${date:now:yyyy-MM-dd'T'HH:mm:ssXXX}","symbol":"ACME"}</camel:simple>
      </camel:setBody>
      <camel:process ref="legacyTransform"/>
      <camel:log message="Legacy feed => ${body}"/>
    </camel:route>

    <!-- Outbound HTTP client legacy: http4:// (componente viejo en Camel 2) -->
    <camel:route id="legacy-http4-outbound">
      <camel:from uri="direct:httpOutbound"/>
      <camel:setHeader headerName="Content-Type">
        <camel:constant>application/json</camel:constant>
      </camel:setHeader>
      <camel:to uri="http4://example.invalid/api/v1/market?throwExceptionOnFailure=false"/>
      <camel:log message="Legacy http4 response => ${header.CamelHttpResponseCode}"/>
    </camel:route>

  </camel:camelContext>
</beans>

